# Copy this file to .env.dreamhost. Do not commit .env.dreamhost.
#
# Recommended: keep SSH details in ~/.ssh/config and refer to the Host alias here.
# Example ~/.ssh/config:
#
# Host nodestrich-dreamhost
#   HostName example.dreamhost.com
#   User your_dreamhost_user
#   IdentityFile ~/.ssh/nodestrich_dreamhost
#   IdentitiesOnly yes

DREAMHOST_SSH_ALIAS=nodestrich-dreamhost

# DreamHost shared hosting webroots are commonly under /home/<user>/<domain>/.
DREAMHOST_REMOTE_PATH=/home/your_dreamhost_user/nodestrich.com/

# Local copy of the current Apache/PHP site.
DREAMHOST_LOCAL_PATH=dreamhost-site/

# Optional. Use this if you need a non-default port or SSH command options.
# DREAMHOST_RSYNC_SSH="ssh -p 22"

# Optional. If password auth is required, put the password in this ignored file.
# Key-based SSH is preferred when available.
# DREAMHOST_PASSWORD_FILE=.dreamhost-password
